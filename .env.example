APP_NAME="Travel Office System"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=travel_office
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
# مدة الجلسة بالدقائق (525600 ≈ سنة). جلسات متعددة بدون خروج تلقائي.
SESSION_LIFETIME=525600
SESSION_EXPIRE_ON_CLOSE=false
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
# true على السيرفر مع HTTPS — false للتطوير المحلي على http
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

BROADCAST_CONNECTION=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

SANCTUM_STATEFUL_DOMAINS=localhost,127.0.0.1
# صلاحية توكن Vue API بالدقائق — اتركه فارغاً = بدون انتهاء (عدة مستخدمين في نفس الوقت)
SANCTUM_EXPIRATION=

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="system@traveloffice.com"
MAIL_FROM_NAME="${APP_NAME}"

# CORS — origins allowed for Vue dev server and Elementor/WordPress integration
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# Regex patterns for dynamic origins (e.g. https://*.elementor.cloud)
CORS_ALLOWED_ORIGINS_PATTERNS=

# PHP_CLI_SERVER_WORKERS=4
