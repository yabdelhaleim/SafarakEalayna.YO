<template>
  <div class="space-y-8 animate-in fade-in duration-700">
    <!-- Page Header -->
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-4">
      <div>
        <h1 class="text-4xl font-extrabold text-text-main tracking-tight">
          لوحة التحكم
        </h1>
        <p class="text-text-muted mt-1">نظرة عامة على جميع عمليات النظام</p>
      </div>
      <div class="flex items-center gap-3">
        <button
          @click="refreshData"
          :disabled="isRefreshing"
          class="px-4 py-2 bg-white/5 hover:bg-white/10 border border-white/10 rounded-xl text-sm font-semibold transition-all flex items-center gap-2 disabled:opacity-50"
        >
          <RefreshCw :class="['w-4 h-4', isRefreshing && 'animate-spin']" />
          تحديث
        </button>
        <button
          @click="exportReport"
          class="px-4 py-2 bg-gold hover:bg-gold/90 text-black rounded-xl text-sm font-bold transition-all flex items-center gap-2 shadow-lg shadow-gold/20"
        >
          <Download class="w-4 h-4" />
          تصدير التقرير
        </button>
      </div>
    </div>

    <!-- Stats Cards Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      <StatCard
        v-for="(stat, index) in store.statsCards"
