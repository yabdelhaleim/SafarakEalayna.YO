          </div>
          <div>
            <div class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1">أرباح اليوم</div>
            <div :class="[
              'text-3xl font-bold tracking-tight',
              kpis.today_profit >= 0 ? 'text-purple-600' : 'text-rose-600'
            ]">{{ formatCompactNumber(kpis.today_profit) }}</div>
            <div class="text-xs text-gray-500 mt-1 font-medium">جنيه</div>
          </div>
        </div>

        <!-- Active Carriers -->
