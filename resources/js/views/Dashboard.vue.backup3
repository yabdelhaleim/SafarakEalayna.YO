        </div>

        <!-- Today's Profit -->
        <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-5 hover:shadow-md transition-all" :class="kpis.today_profit >= 0 ? 'hover:border-purple-300' : 'hover:border-rose-300'">
