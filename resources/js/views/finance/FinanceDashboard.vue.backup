                :class="[
                  'font-mono font-bold',
                  isProfitable ? 'text-blue-500' : 'text-error'
                ]"
              >
                {{ isProfitable ? '+' : '' }}{{ store.stats.net_profit?.toLocaleString() || 0 }}
              </span>
            </div>
            <div class="flex items-center justify-between mt-2">
              <span class="text-sm text-text-muted">نسبة الربح</span>
              <span class="font-mono font-bold text-gold">
