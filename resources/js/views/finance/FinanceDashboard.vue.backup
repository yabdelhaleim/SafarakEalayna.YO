<script setup>
import { ref, computed, onMounted } from 'vue';
import { useFinanceStore } from '@/stores/financeStore';
import { useTransition } from '@vueuse/core';
import {
  Plus,
  Wallet,
  TrendingUp,
  TrendingDown,
  DollarSign,
  Building2,
  FileText,
  ArrowUpRight,
  ArrowDownRight,
  ArrowRightLeft,
  ArrowLeft,
} from 'lucide-vue-next';

const store = useFinanceStore();

// Animated stats
const totalBalanceSource = ref(0);
const totalIncomeSource = ref(0);
const totalExpenseSource = ref(0);
const netProfitSource = ref(0);

const totalBalanceOutput = useTransition(totalBalanceSource, { duration: 1500 });
const totalIncomeOutput = useTransition(totalIncomeSource, { duration: 1500 });
const totalExpenseOutput = useTransition(totalExpenseSource, { duration: 1500 });
const netProfitOutput = useTransition(netProfitSource, { duration: 1500 });

const animatedStats = computed(() => ({
  total_balance: Math.floor(totalBalanceOutput.value).toLocaleString(),
  total_income: Math.floor(totalIncomeOutput.value).toLocaleString(),
  total_expense: Math.floor(totalExpenseOutput.value).toLocaleString(),
  net_profit: (Math.floor(netProfitOutput.value) >= 0 ? '+' : '') + Math.floor(netProfitOutput.value).toLocaleString(),
}));

// Bank accounts (bank + cash)
const bankAccounts = computed(() => {
  return store.accounts.filter((a) => ['bank', 'cash'].includes(a.type));
});

// Recent transactions
const recentTransactions = computed(() => store.recentTransactions);

// Is profitable
const isProfitable = computed(() => (store.stats.net_profit || 0) >= 0);

// Income percentage
const incomePercentage = computed(() => {
  const total = store.stats.total_income + store.stats.total_expense;
  return total > 0 ? (store.stats.total_income / total) * 100 : 0;
});

// Expense percentage
const expensePercentage = computed(() => {
  const total = store.stats.total_income + store.stats.total_expense;
  return total > 0 ? (store.stats.total_expense / total) * 100 : 0;
});

// Profit margin
const profitMargin = computed(() => {
  if (store.stats.total_income === 0) return 0;
  return ((store.stats.net_profit / store.stats.total_income) * 100).toFixed(1);
});

// Format date
const formatDate = (dateString) => {
  if (!dateString) return '';
  const date = new Date(dateString);
  return date.toLocaleDateString('ar-EG', {
    year: 'numeric',
    month: 'short',
    day: 'numeric',
  });
};

// Load data
onMounted(async () => {
  await Promise.all([
    store.fetchAccounts(),
    store.fetchTransactions(),
    store.fetchStats(),
  ]);

  // Animate stats
  totalBalanceSource.value = store.stats.total_balance || 0;
  totalIncomeSource.value = store.stats.total_income || 0;
  totalExpenseSource.value = store.stats.total_expense || 0;
  netProfitSource.value = store.stats.net_profit || 0;
});
</script>

<style scoped>
.bg-card-bg {
  background-color: var(--card-bg);
}

.bg-input-bg {
  background-color: var(--input-bg);
}

.text-text-main {
  color: var(--text-main);
}

.text-text-muted {
  color: var(--text-muted);
}

.text-gold {
  color: var(--gold);
}

.bg-gold {
  background-color: var(--gold);
}

.text-success {
  color: var(--success);
}

.text-error {
  color: var(--error);
}

.bg-success {
  background-color: var(--success);
}

.bg-error {
  background-color: var(--error);
}

.font-display {
  font-family: 'IBM Plex Sans Arabic', sans-serif;
}

.font-mono {
  font-family: 'IBM Plex Sans Arabic', sans-serif;
}
</style>
