            الدخل مقابل المصروف
          </h3>

          <!-- Simple Bar Chart -->
          <div class="space-y-4">
            <div>
              <div class="flex items-center justify-between mb-2">
                <span class="text-sm text-text-muted">إجمالي الدخل</span>
