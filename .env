APP_NAME=safarakealayna
APP_ENV=local
APP_KEY=base64:emyd9BOWjBl/dhena8D1ycdyvDso0hLd+08Xpm6Gp2E=
APP_DEBUG=true
APP_URL=http://127.0.0.1:8000

APP_LOCALE=ar
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=ar_SA

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# عدد عمليات PHP المتوازية لـ artisan serve (Linux/Mac). على Windows استخدم Laragon Apache بدلاً منه.
PHP_CLI_SERVER_WORKERS=4

# عند استخدام Laragon Apache: composer dev:laragon + APP_URL=http://safarakealayna.test
# VITE_DEV_PROXY_TARGET=http://safarakealayna.test

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=safarakealayna
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
# مدة الجلسة بالدقائق (525600 ≈ سنة). جلسات متعددة بدون خروج تلقائي.
SESSION_LIFETIME=120
SESSION_EXPIRE_ON_CLOSE=false
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
# false للتطوير المحلي (http). غيّرها لـ true على السيرفر إذا الموقع HTTPS.
SESSION_SECURE_COOKIE=false
SESSION_SAME_SITE=lax

SANCTUM_STATEFUL_DOMAINS=localhost,localhost:5173,localhost:8000,127.0.0.1,127.0.0.1:8000,127.0.0.1:5173,::1
# صلاحية توكن Vue API بالدقائق (120 دقيقة = ساعتان)
SANCTUM_EXPIRATION=120

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
TELESCOPE_ENABLED=true