# -----------------------------------------------------------------------------
# .env.production.example — production overrides for the Travel Office System
# Copy to .env on the server, then run: php artisan key:generate
# -----------------------------------------------------------------------------

APP_NAME="Travel Office System"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://your-domain.com

APP_LOCALE=ar
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

# ---- logging --------------------------------------------------------------
LOG_CHANNEL=daily
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# ---- database (MySQL / MariaDB) -------------------------------------------
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=travel_office
DB_USERNAME=travel_app
DB_PASSWORD=change-me-strong-password

# ---- session / cache / queue ----------------------------------------------
# Database is fine but for heavy traffic switch CACHE to redis.
SESSION_DRIVER=database
SESSION_LIFETIME=525600
SESSION_EXPIRE_ON_CLOSE=false
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
# MUST be true behind HTTPS in production.
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

BROADCAST_CONNECTION=log
CACHE_STORE=database
CACHE_PREFIX=
FILESYSTEM_DISK=local
# database needs `php artisan queue:work` running under systemd / supervisord.
QUEUE_CONNECTION=database

# ---- sanctum (Vue SPA / API tokens) ---------------------------------------
SANCTUM_STATEFUL_DOMAINS=your-domain.com,www.your-domain.com
SANCTUM_EXPIRATION=

# ---- mail (SMTP via your provider) ----------------------------------------
MAIL_MAILER=smtp
MAIL_HOST=smtp.your-provider.com
MAIL_PORT=587
MAIL_USERNAME=system@your-domain.com
MAIL_PASSWORD=change-me
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="system@your-domain.com"
MAIL_FROM_NAME="${APP_NAME}"

# ---- CORS (your frontend origin + Elementor embed) -----------------------
CORS_ALLOWED_ORIGINS=https://your-frontend.com
CORS_ALLOWED_ORIGINS_PATTERNS=https://*.elementor.cloud

# ---- trusted proxies (Nginx in front of PHP-FPM) -------------------------
# TRUSTED_PROXIES="*"
