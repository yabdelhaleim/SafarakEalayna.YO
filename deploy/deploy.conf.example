# -----------------------------------------------------------------------------
# deploy.conf — local overrides for deploy.sh
# Copy this file to `deploy.conf` next to deploy.sh and edit values.
# Anything you don't set falls back to the defaults baked into deploy.sh.
# -----------------------------------------------------------------------------

# Path on the server where the Laravel project lives.
#APP_DIR="/var/www/safarakEalayna"

# Linux user that owns the application files (matches Nginx/PHP-FPM).
#APP_USER="www-data"
#APP_GROUP="www-data"

# systemd unit name for your PHP-FPM service.
#PHP_FPM_SERVICE="php8.3-fpm"

# Where deploy logs (.env backups, per-run logs) are written.
#LOG_DIR="/var/log/safarak-deploy"
